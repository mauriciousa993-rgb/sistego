MONGO_URI=mongodb://127.0.0.1:27017/sistego
PORT=4000

# Auth (obligatorio)
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=8h

# Registro (prod recomendado)
# - DISABLE_PUBLIC_REGISTER=true bloquea registro público incluso en bootstrap
# - ALLOW_PUBLIC_REGISTER=true habilita registro público (solo dev)
DISABLE_PUBLIC_REGISTER=true
ALLOW_PUBLIC_REGISTER=false

# Auditoría (opcional)
AUDIT_ENABLED=true

# Facturación
INVOICE_PROVIDER=mock # mock | pt
PT_DRY_RUN=true

# DIAN / PT (para integrar real)
DIAN_ENV=HABILITACION # HABILITACION | PRODUCCION
DIAN_NIT=900000000
DIAN_DV=1
DIAN_ISSUER_NAME=Mi Empresa SAS
DIAN_SOFTWARE_ID=your-software-id
DIAN_SOFTWARE_PIN=your-software-pin
DIAN_TECHNICAL_KEY=
DIAN_TEST_SET_ID=

# Certificado (si aplica a tu integración)
DIAN_CERT_BASE64=
DIAN_CERT_PASSWORD=

# Endpoint/credenciales PT
PT_API_BASE_URL=
PT_API_KEY=

# Cloudinary (imágenes productos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=sistego/products
CLOUDINARY_FOLDER_RUT=sistego/rut
CLOUDINARY_FOLDER_PAYMENTS=sistego/payments

# OpenAI (leer RUT / autocompletar cliente)
OPENAI_API_KEY=
OPENAI_MODEL_RUT=gpt-4o-mini
